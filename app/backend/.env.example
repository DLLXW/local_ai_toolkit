LOCAL_AI_APP_NAME=Local AI Toolkit Backend
LOCAL_AI_APP_ENV=development
LOCAL_AI_DEBUG=true

LOCAL_AI_OCR_BASE_URL=http://127.0.0.1:8080
LOCAL_AI_OCR_CHAT_PATH=/chat/completions
LOCAL_AI_OCR_MODEL=mlx-community/GLM-OCR-bf16
LOCAL_AI_OCR_TIMEOUT_SECONDS=180

LOCAL_AI_TRANSLATE_BASE_URL=http://127.0.0.1:8090
LOCAL_AI_TRANSLATE_CHAT_PATH=/v1/chat/completions
LOCAL_AI_TRANSLATE_MODEL=HY-MT1.5
LOCAL_AI_TRANSLATE_TIMEOUT_SECONDS=120
LOCAL_AI_TRANSLATE_RETRY_ATTEMPTS=3
LOCAL_AI_TRANSLATE_RETRY_BACKOFF_SECONDS=1.5
LOCAL_AI_TRANSLATE_MAX_CHARS_PER_CHUNK=900
